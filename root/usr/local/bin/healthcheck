#!/command/with-contenv bash
# Docker HEALTHCHECK — verifies VPN tunnel and web UI are functional

PORT="${UI_PORT:-6050}"

# Check WireGuard interface is up with a handshake
if ! wg show wg0 latest-handshakes 2>/dev/null | grep -q '[0-9]'; then
    echo "UNHEALTHY: wg0 has no peer handshakes"
    exit 1
fi

# Check web UI responds
if ! curl -fsS -m 5 "http://localhost:${PORT}/api/stats/latest" > /dev/null 2>&1; then
    echo "UNHEALTHY: web UI not responding"
    exit 1
fi

exit 0
